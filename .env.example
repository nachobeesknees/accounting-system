# Postgres connection string. Local Postgres or Neon's pooled endpoint
# both work — the app speaks the standard wire protocol via postgres-js.
DATABASE_URL=postgres://localhost:5432/thistlewood

# 32+ random bytes used to HMAC-sign the session cookie. Generate with
# `openssl rand -base64 32`. Falls back to a dev string if unset.
SESSION_SECRET=

# Sentry DSN for client + server error reporting. Leave empty to run
# without telemetry — the SDK is wired up but no-ops when this is unset.
NEXT_PUBLIC_SENTRY_DSN=
