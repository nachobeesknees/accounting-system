  "design_principles": [
    "Core engine has ZERO jurisdiction-specific code",
    "All country logic lives in pluggable modules",
    "Modules are versioned independently",
    "Account templates per jurisdiction but data model is shared",
    "Module interface is identical across all jurisdictions",
    "Self-registration pattern (no central config)",
    "Lazy loading (modules load on demand)",
    "Singleton registry (single source of truth)"
  ],

