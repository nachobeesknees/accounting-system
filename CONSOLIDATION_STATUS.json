  "models_schema": {
    "IntercompanyTransaction": {
      "fields": [
        "sender_entry (FK JournalEntry)",
        "receiver_entry (FK JournalEntry)",
        "status (matched | mismatched | resolved)",
        "mismatch_type (amount | currency | date | account | missing_pair | other)",
        "mismatch_detail (text)",
        "tolerance_percent (decimal)",
        "resolved_at, resolved_by, resolution_notes"
      ],
      "indexes": ["sender_entry, receiver_entry", "status", "mismatch_type"]
    },
    "ConsolidationRun": {
      "fields": [
        "as_of_date (date)",
        "reporting_currency (char 3)",
        "parent_entity (FK Entity)",
        "entities_in_scope (list)",
        "status (in_progress | complete | blocked | finalized)",
        "started_at, completed_at, executed_by"
      ],
      "indexes": ["parent_entity, as_of_date", "status"]
    },
    "ConsolidationAdjustment": {
      "fields": [
        "consolidation_run (FK)",
        "adjustment_type (elimination | basis_normalization | reclassification | translation | minority_interest)",
        "description (text)",
        "status (draft | applied)",
        "intercompany_transaction (FK, optional)"
      ],
      "indexes": ["consolidation_run, adjustment_type", "consolidation_run, status"]
    },
    "ConsolidationAdjustmentLine": {
      "fields": [
        "adjustment (FK)",
        "line_number (int)",
        "consolidation_account (FK)",
        "debit, credit (decimal)",
        "currency (char 3)",
        "description (text)"
      ]
    },
    "Dimension": {
      "fields": [
        "entity (FK)",
        "dimension_type (department | class | location | project | custom)",
        "name, code (text)",
        "parent (FK self, optional)"
      ],
      "unique_constraint": "entity, dimension_type, code"
    }
  },
